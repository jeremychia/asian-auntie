# Flask
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-generate-a-real-secret

# JWT — must be different from FLASK_SECRET_KEY
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-generate-a-different-secret

# Database — leave as SQLite for local dev; set to Render's PostgreSQL URL in prod
DATABASE_URL=sqlite:///app.db

# OpenAI Vision API — leave blank to use stub mode (app works without it)
OPENAI_API_KEY=

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Environment: development or production
FLASK_ENV=development

# CORS allowed origins — comma-separated, no spaces
# In production: set to your Render domain, e.g. https://asian-auntie.onrender.com
ALLOWED_ORIGINS=http://localhost:8080
